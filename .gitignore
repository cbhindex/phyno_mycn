# =============================================================================
# .gitignore — PRE-PUBLICATION variant (ACTIVE)
#
# The trained model weights and their per-fold metrics are WITHHELD from the
# repository until the manuscript is published. After publication, swap in the
# release variant and stage the weights (see PUBLICATION.md):
#       cp .gitignore.release .gitignore
#       git add -f plug_and_play/weights/        # then commit
# =============================================================================

# Byte-compiled / optimized / cache
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# Python packaging / editable-install artifacts
*.egg-info/
*.egg
.eggs/
build/
dist/

# Environments
.env
.venv
env/
venv/
ENV/

# IDE / OS
.idea/
.vscode/
.DS_Store

# Logs and lightning run dirs
*.log
neuro_logs/
lightning_logs/
wandb/

# Large data and derived artefacts (NOT distributed in this repo)
# Tile embeddings, whole-slide images, and per-slide inference dumps are
# patient-derived and/or too large for version control.
data/wsi_embeddings/
data/**/*.pt
data/**/*.h5
data/**/*.svs
data/**/*.ndpi
results/
*.npy

# Model checkpoints and saved tensors.
*.ckpt
*.pth
*.pt

# --- Confidential until publication ---
# The trained plug-and-play checkpoint and its per-fold metrics are withheld for
# now. (Deliberately NOT re-included; the release variant re-includes them.)
plug_and_play/weights/*.ckpt
plug_and_play/weights/*.csv
